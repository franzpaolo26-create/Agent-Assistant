# ═══════════════════════════════════════════════════════════════════
#   JARVIS OS — Variables de Entorno
#   Copia este archivo: cp .env.example .env
#   NUNCA commitees el .env real a Git
# ═══════════════════════════════════════════════════════════════════

# ─── APIs de IA ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── Ollama (corre en Docker, servicio 'ollama') ──────────────────
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_OLLAMA_MODEL=llama3.2
CLASSIFIER_MODEL=llama3.2       # Modelo para clasificar intención (gratuito)
WHISPER_STRATEGY=auto           # 'ollama' | 'binary' | 'auto'
WHISPER_MODEL=whisper           # Modelo Ollama para transcripción
WHISPER_MODEL_PATH=base         # Ruta modelo whisper.cpp si usas binario

# ─── Modelos ─────────────────────────────────────────────────────
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─── ChromaDB (RAG — corre en Docker) ────────────────────────────
CHROMA_URL=http://chromadb:8000
EMBED_MODEL=nomic-embed-text    # Modelo de embeddings (descargado en Ollama)

# ─── WhatsApp ────────────────────────────────────────────────────
# Número con código de país + @c.us (SIN el +)
OWNER_NUMBER=34614146892@c.us

# ─── Google Workspace ────────────────────────────────────────────
# Configurado automáticamente por OAuth2 (token.json se genera al iniciar)
GMAIL_VIP=jefe@empresa.com,cliente@corp.com   # Emails de alta prioridad (P1)

# ─── TTS (Text-to-Speech) ────────────────────────────────────────
TTS_VOICE=es-ES-AlvaroNeural    # Voz masculina española (edge-tts)

# ─── Seguridad del Shell ─────────────────────────────────────────
SHELL_UNRESTRICTED=false        # true = sin restricciones (PELIGROSO)

# ─── Servidor / Dashboard ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Tailscale (Fase 2) ──────────────────────────────────────────
# TAILSCALE_AUTH_KEY=tskey-auth-...
# TAILSCALE_API_KEY=tskey-api-...

# ─── FinOps — Alertas de presupuesto ─────────────────────────────
BUDGET_DAILY_USD=0.50           # Alerta si se supera este gasto diario
BUDGET_MONTHLY_EUR=20           # Presupuesto mensual objetivo
