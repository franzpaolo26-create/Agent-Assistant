# ─── APIs de IA ─────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Ollama ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=llama3.1:8b

# ─── Modelos ─────────────────────────────────────
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─── WhatsApp ────────────────────────────────────
OWNER_NUMBER=34XXXXXXXXX@c.us

# ─── Dashboard ───────────────────────────────────
PORT=3000
